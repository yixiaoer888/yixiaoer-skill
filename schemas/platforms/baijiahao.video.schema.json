{
  "title": "百家号视频发布表单 (BaiJiaHao Video)",
  "type": "object",
  "required": [
    "formType",
    "title",
    "description",
    "tags",
    "pubType"
  ],
  "properties": {
    "formType": {
      "type": "string",
      "const": "task"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 30
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "pubType": {
      "type": "number",
      "enum": [
        0,
        1
      ],
      "default": 1
    },
    "declaration": {
      "type": "number",
      "enum": [
        0,
        1
      ],
      "default": 0
    },
    "location": {
      "type": "object",
      "required": [
        "yixiaoerId",
        "yixiaoerName",
        "raw"
      ],
      "properties": {
        "yixiaoerId": {
          "type": "string"
        },
        "yixiaoerName": {
          "type": "string"
        },
        "raw": {
          "type": "object"
        }
      }
    },
    "collection": {
      "type": "object",
      "required": [
        "yixiaoerId",
        "yixiaoerName",
        "raw"
      ],
      "properties": {
        "yixiaoerId": {
          "type": "string"
        },
        "yixiaoerName": {
          "type": "string"
        },
        "raw": {
          "type": "object"
        }
      }
    },
    "activity": {
      "type": "object",
      "required": [
        "yixiaoerId",
        "yixiaoerName",
        "raw"
      ],
      "properties": {
        "yixiaoerId": {
          "type": "string"
        },
        "yixiaoerName": {
          "type": "string"
        },
        "raw": {
          "type": "object"
        }
      }
    },
    "video": {
      "type": "object",
      "required": [
        "key",
        "size",
        "width",
        "height"
      ],
      "properties": {
        "key": {
          "type": "string"
        },
        "size": {
          "type": "integer",
          "minimum": 1
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "duration": {
          "type": "number",
          "minimum": 1
        },
        "format": {
          "type": "string",
          "enum": [
            "mp4",
            "mov",
            "flv",
            "avi"
          ]
        }
      }
    },
    "cover": {
      "type": "object",
      "required": [
        "key",
        "size",
        "width",
        "height"
      ],
      "properties": {
        "key": {
          "type": "string"
        },
        "size": {
          "type": "integer"
        },
        "width": {
          "type": "integer"
        },
        "height": {
          "type": "integer"
        }
      }
    },
    "coverKey": {
      "type": "string"
    },
    "scheduledTime": {
      "type": "number",
      "minimum": 0
    }
  },
  "additionalProperties": false
}
