{
  "title": "头条号文章发布表单 (ToutiaoHao Article)",
  "type": "object",
  "required": [
    "formType",
    "title",
    "content",
    "covers"
  ],
  "properties": {
    "formType": {
      "type": "string",
      "const": "task"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50
    },
    "content": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50000
    },
    "covers": {
      "type": "array",
      "minItems": 1,
      "maxItems": 9,
      "items": {
        "type": "object",
        "required": [
          "key",
          "size",
          "width",
          "height"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "size": {
            "type": "integer",
            "minimum": 1
          },
          "width": {
            "type": "integer",
            "minimum": 1
          },
          "height": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "coverKey": {
      "type": "string"
    },
    "thumbMediaId": {
      "type": "string"
    },
    "category": {
      "type": "object",
      "required": [
        "yixiaoerId",
        "yixiaoerName",
        "raw"
      ],
      "properties": {
        "yixiaoerId": {
          "type": "string"
        },
        "yixiaoerName": {
          "type": "string"
        },
        "raw": {
          "type": "object"
        }
      }
    },
    "original": {
      "type": "boolean",
      "default": false
    },
    "originalType": {
      "type": "number",
      "enum": [
        0,
        1,
        2
      ]
    },
    "originalUrl": {
      "type": "string",
      "format": "uri"
    },
    "pubType": {
      "type": "number",
      "enum": [
        0,
        1
      ],
      "default": 1
    },
    "isFirst": {
      "type": "boolean",
      "default": false
    },
    "location": {
      "type": "object",
      "required": [
        "yixiaoerId",
        "yixiaoerName",
        "raw"
      ],
      "properties": {
        "yixiaoerId": {
          "type": "string"
        },
        "yixiaoerName": {
          "type": "string"
        },
        "raw": {
          "type": "object"
        }
      }
    },
    "scheduledTime": {
      "type": "number",
      "minimum": 0
    },
    "advertisement": {
      "type": "number",
      "enum": [
        2,
        3
      ],
      "default": 3
    },
    "declaration": {
      "type": "number",
      "enum": [
        1,
        2,
        3,
        6,
        7,
        8
      ]
    },
    "statement": {
      "type": "number",
      "enum": [
        1,
        2,
        3
      ]
    },
    "publishTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
