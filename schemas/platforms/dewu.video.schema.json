{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://www.yixiaoer.cn/schemas/platforms/dewu.video.schema.json",
  "title": "得物视频发布表单 (Dewu Video)",
  "type": "object",
  "required": ["formType", "title", "description", "declaration"],
  "properties": {
    "formType":       { "type": "string", "const": "task" },
    "title":           { "type": "string", "minLength": 1 },
    "description":     { "type": "string", "minLength": 1 },
    "declaration":      { "type": "number", "enum": [0, 1, 2, 3, 4] },
    "category": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text", "raw"],
        "properties": {
          "id":   { "type": "string" },
          "text": { "type": "string" },
          "raw":  { "type": "object" }
        }
      }
    },
    "video": {
      "type": "object",
      "required": ["key", "size", "width", "height"],
      "properties": {
        "key":      { "type": "string" },
        "size":     { "type": "integer", "minimum": 1 },
        "width":    { "type": "integer", "minimum": 1 },
        "height":   { "type": "integer", "minimum": 1 },
        "duration": { "type": "number", "minimum": 1 },
        "format":   { "type": "string", "enum": ["mp4", "mov", "flv", "avi"] }
      }
    },
    "cover": {
      "type": "object",
      "required": ["key", "size", "width", "height"],
      "properties": {
        "key":    { "type": "string" },
        "size":   { "type": "integer" },
        "width":  { "type": "integer" },
        "height": { "type": "integer" }
      }
    },
    "coverKey":      { "type": "string" },
    "scheduledTime": { "type": "number", "minimum": 0 },
    "pubType":        { "type": "number", "enum": [0, 1], "default": 1 }
  },
  "additionalProperties": false
}
