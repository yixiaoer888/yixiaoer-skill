{
  "title": "哔哩哔哩文章发布表单 (Bilibili Article)",
  "type": "object",
  "required": [
    "formType",
    "title",
    "content",
    "covers",
    "pubType"
  ],
  "properties": {
    "formType": {
      "type": "string",
      "const": "task"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "content": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100000
    },
    "covers": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "object",
        "required": [
          "key",
          "size",
          "width",
          "height"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "size": {
            "type": "integer",
            "minimum": 1
          },
          "width": {
            "type": "integer",
            "minimum": 1
          },
          "height": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "pubType": {
      "type": "number",
      "enum": [
        0,
        1
      ],
      "default": 1
    },
    "tags": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "string",
        "maxLength": 20
      }
    },
    "createType": {
      "type": "number",
      "enum": [
        0,
        1
      ],
      "default": 1
    },
    "category": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "yixiaoerId",
          "yixiaoerName",
          "raw"
        ],
        "properties": {
          "yixiaoerId": {
            "type": "string"
          },
          "yixiaoerName": {
            "type": "string"
          },
          "raw": {
            "type": "object"
          }
        }
      }
    },
    "scheduledTime": {
      "type": "number",
      "minimum": 0
    }
  },
  "additionalProperties": false
}
