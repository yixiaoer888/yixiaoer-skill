{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://www.yixiaoer.cn/schemas/platforms/souhuhao.article.schema.json",
  "title": "搜狐号文章发布表单 (SouHuHao Article)",
  "type": "object",
  "required": ["formType", "title", "content", "desc", "covers", "pubType"],
  "properties": {
    "formType":      { "type": "string", "const": "task" },
    "title":         { "type": "string", "minLength": 1 },
    "content":       { "type": "string", "minLength": 1 },
    "desc":          { "type": "string", "minLength": 1 },
    "covers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["key", "size", "width", "height"],
        "properties": {
          "key":    { "type": "string" },
          "size":   { "type": "integer", "minimum": 1 },
          "width":  { "type": "integer", "minimum": 1 },
          "height": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "pubType":       { "type": "number", "enum": [0, 1], "default": 1 },
    "scheduledTime": { "type": "number", "minimum": 0 }
  },
  "additionalProperties": false
}
