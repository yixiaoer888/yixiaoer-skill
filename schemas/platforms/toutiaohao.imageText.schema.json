{
  "title": "头条号图文发布表单 (ToutiaoHao Image-Text)",
  "type": "object",
  "required": [
    "formType",
    "description",
    "images",
    "pubType"
  ],
  "properties": {
    "formType": {
      "type": "string",
      "const": "task"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "images": {
      "type": "array",
      "minItems": 1,
      "maxItems": 18,
      "items": {
        "type": "object",
        "required": [
          "key",
          "size",
          "width",
          "height",
          "format"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "size": {
            "type": "integer",
            "minimum": 1
          },
          "width": {
            "type": "integer",
            "minimum": 1
          },
          "height": {
            "type": "integer",
            "minimum": 1
          },
          "format": {
            "type": "string",
            "enum": [
              "jpg",
              "jpeg",
              "png",
              "webp",
              "gif"
            ]
          }
        }
      }
    },
    "declaration": {
      "type": "number",
      "enum": [
        1,
        2,
        3,
        6,
        7,
        8
      ]
    },
    "pubType": {
      "type": "number",
      "enum": [
        0,
        1
      ],
      "default": 1
    }
  },
  "additionalProperties": false
}
