{
  "title": "易车号文章发布表单 (YiCheHao Article)",
  "type": "object",
  "required": [
    "formType",
    "title",
    "content",
    "covers",
    "verticalCovers",
    "pubType"
  ],
  "properties": {
    "formType": {
      "type": "string",
      "const": "task"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 28
    },
    "content": {
      "type": "string",
      "minLength": 1
    },
    "covers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "key",
          "size",
          "width",
          "height"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "size": {
            "type": "integer",
            "minimum": 1
          },
          "width": {
            "type": "integer",
            "minimum": 1
          },
          "height": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "verticalCovers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "key",
          "size",
          "width",
          "height"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "size": {
            "type": "integer",
            "minimum": 1
          },
          "width": {
            "type": "integer",
            "minimum": 1
          },
          "height": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "pubType": {
      "type": "number",
      "enum": [
        0,
        1
      ],
      "default": 1
    },
    "declaration": {
      "type": "number",
      "enum": [
        0,
        1,
        2,
        3,
        4
      ]
    },
    "allowForward": {
      "type": "boolean",
      "default": false
    },
    "allowAbstract": {
      "type": "boolean",
      "default": false
    },
    "topics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "yixiaoerId",
          "yixiaoerName",
          "raw"
        ],
        "properties": {
          "yixiaoerId": {
            "type": "string"
          },
          "yixiaoerName": {
            "type": "string"
          },
          "raw": {
            "type": "object"
          }
        }
      }
    },
    "scheduledTime": {
      "type": "number",
      "minimum": 0
    }
  },
  "additionalProperties": false
}
