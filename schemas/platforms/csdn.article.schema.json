{
  "title": "CSDN 文章发布表单 (CSDN Article)",
  "type": "object",
  "required": [
    "formType",
    "title",
    "content",
    "desc",
    "covers",
    "tags",
    "createType",
    "pubType"
  ],
  "properties": {
    "formType": {
      "type": "string",
      "const": "task"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "content": {
      "type": "string",
      "minLength": 1
    },
    "desc": {
      "type": "string",
      "minLength": 1
    },
    "covers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "key",
          "size",
          "width",
          "height"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "size": {
            "type": "integer",
            "minimum": 1
          },
          "width": {
            "type": "integer",
            "minimum": 1
          },
          "height": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "createType": {
      "type": "number",
      "enum": [
        1,
        2,
        4
      ],
      "default": 1
    },
    "pubType": {
      "type": "number",
      "enum": [
        0,
        1
      ],
      "default": 1
    },
    "declaration": {
      "type": "number",
      "enum": [
        0,
        1,
        2,
        3
      ],
      "default": 0
    },
    "contentSourceUrl": {
      "type": "string",
      "format": "uri"
    },
    "scheduledTime": {
      "type": "number",
      "minimum": 0
    }
  },
  "additionalProperties": false
}
