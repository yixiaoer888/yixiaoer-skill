{
  "title": "快手视频发布表单 (Kuaishou Video)",
  "type": "object",
  "required": [
    "formType",
    "title",
    "description",
    "video"
  ],
  "properties": {
    "formType": {
      "type": "string",
      "const": "task"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50
    },
    "description": {
      "type": "string",
      "minLength": 0,
      "maxLength": 1000
    },
    "video": {
      "type": "object",
      "required": [
        "key",
        "size",
        "width",
        "height"
      ],
      "properties": {
        "key": {
          "type": "string"
        },
        "size": {
          "type": "integer",
          "minimum": 1
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "duration": {
          "type": "number",
          "minimum": 1
        },
        "format": {
          "type": "string",
          "enum": [
            "mp4",
            "mov"
          ]
        }
      }
    },
    "cover": {
      "type": "object",
      "required": [
        "key",
        "size",
        "width",
        "height"
      ],
      "properties": {
        "key": {
          "type": "string"
        },
        "size": {
          "type": "integer"
        },
        "width": {
          "type": "integer"
        },
        "height": {
          "type": "integer"
        }
      }
    },
    "coverKey": {
      "type": "string"
    },
    "location": {
      "type": "object",
      "required": [
        "yixiaoerId",
        "yixiaoerName",
        "raw"
      ],
      "properties": {
        "yixiaoerId": {
          "type": "string"
        },
        "yixiaoerName": {
          "type": "string"
        },
        "raw": {
          "type": "object"
        }
      }
    },
    "music": {
      "type": "object",
      "required": [
        "yixiaoerId",
        "yixiaoerName",
        "raw"
      ],
      "properties": {
        "yixiaoerId": {
          "type": "string"
        },
        "yixiaoerName": {
          "type": "string"
        },
        "duration": {
          "type": "number"
        },
        "playUrl": {
          "type": "string"
        },
        "raw": {
          "type": "object"
        }
      }
    },
    "challenge": {
      "type": "object",
      "required": [
        "yixiaoerId",
        "yixiaoerName",
        "raw"
      ],
      "properties": {
        "yixiaoerId": {
          "type": "string"
        },
        "yixiaoerName": {
          "type": "string"
        },
        "raw": {
          "type": "object"
        }
      }
    },
    "collection": {
      "type": "object",
      "required": [
        "yixiaoerId",
        "yixiaoerName",
        "raw"
      ],
      "properties": {
        "yixiaoerId": {
          "type": "string"
        },
        "yixiaoerName": {
          "type": "string"
        },
        "raw": {
          "type": "object"
        }
      }
    },
    "pubType": {
      "type": "number",
      "enum": [
        0,
        1
      ],
      "default": 1
    },
    "visibleType": {
      "type": "number",
      "enum": [
        0,
        1,
        2
      ],
      "default": 0
    }
  },
  "additionalProperties": false
}
