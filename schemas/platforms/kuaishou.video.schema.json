{
  "title": "快手视频发布表单 (Kuaishou Video)",
  "type": "object",
  "required": ["formType"],
  "properties": {
    "formType": {
      "type": "string",
      "const": "task"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50
    },
    "description": {
      "type": "string",
      "minLength": 0,
      "maxLength": 1000
    },
    "video": {
      "type": "object",
      "required": [
        "key",
        "size",
        "width",
        "height"
      ],
      "properties": {
        "key": {
          "type": "string"
        },
        "size": {
          "type": "integer",
          "minimum": 1
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "duration": {
          "type": "number",
          "minimum": 1
        },
        "format": {
          "type": "string",
          "enum": [
            "mp4",
            "mov"
          ]
        }
      }
    },
    "cover": {
      "type": "object",
      "required": [
        "key",
        "size",
        "width",
        "height"
      ],
      "properties": {
        "key": {
          "type": "string"
        },
        "size": {
          "type": "integer"
        },
        "width": {
          "type": "integer"
        },
        "height": {
          "type": "integer"
        }
      }
    },
    "coverKey": {
      "type": "string"
    },
    "location": {
      "type": "object",
      "required": [
        "yixiaoerId",
        "yixiaoerName",
        "raw"
      ],
      "properties": {
        "yixiaoerId": {
          "type": "string"
        },
        "yixiaoerName": {
          "type": "string"
        },
        "raw": {
          "type": "object"
        }
      }
    },
    "music": {
      "type": "object",
      "required": [
        "yixiaoerId",
        "yixiaoerName",
        "raw"
      ],
      "properties": {
        "yixiaoerId": {
          "type": "string"
        },
        "yixiaoerName": {
          "type": "string"
        },
        "duration": {
          "type": "number"
        },
        "playUrl": {
          "type": "string"
        },
        "raw": {
          "type": "object"
        }
      }
    },
    "challenge": {
      "type": "object",
      "required": [
        "yixiaoerId",
        "yixiaoerName",
        "raw"
      ],
      "properties": {
        "yixiaoerId": {
          "type": "string"
        },
        "yixiaoerName": {
          "type": "string"
        },
        "raw": {
          "type": "object"
        }
      }
    },
    "collection": {
      "type": "object",
      "required": [
        "yixiaoerId",
        "yixiaoerName",
        "raw"
      ],
      "properties": {
        "yixiaoerId": {
          "type": "string"
        },
        "yixiaoerName": {
          "type": "string"
        },
        "raw": {
          "type": "object"
        }
      }
    },
    "visibleType": {
      "type": "number",
      "enum": [
        0,
        1,
        3
      ],
      "default": 0
    },
    "declaration": {
      "type": "number",
      "enum": [
        0,
        1,
        2,
        3
      ],
      "default": 0
    },
    "scheduledTime": {
      "type": "number",
      "minimum": 0
    },
    "shopping_cart": {
      "type": "object",
      "required": [
        "yixiaoerId",
        "yixiaoerName",
        "raw"
      ],
      "properties": {
        "yixiaoerId": {
          "type": "string"
        },
        "yixiaoerName": {
          "type": "string"
        },
        "raw": {
          "type": "object"
        }
      }
    },
    "mini_app": {
      "type": "object",
      "required": [
        "yixiaoerId",
        "yixiaoerName",
        "raw"
      ],
      "properties": {
        "yixiaoerId": {
          "type": "string"
        },
        "yixiaoerName": {
          "type": "string"
        },
        "raw": {
          "type": "object"
        }
      }
    },
    "nearby_show": {
      "type": "boolean",
      "default": true
    },
    "allow_same_frame": {
      "type": "boolean",
      "default": false
    },
    "allow_download": {
      "type": "boolean",
      "default": false
    }
  },
  "additionalProperties": false
}
