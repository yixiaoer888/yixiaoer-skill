{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://www.yixiaoer.cn/schemas/platforms/meiyou.video.schema.json",
  "title": "美柚视频发布表单 (Meiyou Video)",
  "type": "object",
  "required": ["formType", "title"],
  "properties": {
    "formType":    { "type": "string", "const": "task" },
    "title":         { "type": "string", "minLength": 1 },
    "video": {
      "type": "object",
      "required": ["key", "size", "width", "height"],
      "properties": {
        "key":      { "type": "string" },
        "size":     { "type": "integer", "minimum": 1 },
        "width":    { "type": "integer", "minimum": 1 },
        "height":   { "type": "integer", "minimum": 1 },
        "duration": { "type": "number", "minimum": 1 },
        "format":   { "type": "string", "enum": ["mp4", "mov", "flv", "avi"] }
      }
    },
    "cover": {
      "type": "object",
      "required": ["key", "size", "width", "height"],
      "properties": {
        "key":    { "type": "string" },
        "size":   { "type": "integer" },
        "width":  { "type": "integer" },
        "height": { "type": "integer" }
      }
    },
    "coverKey":      { "type": "string" },
    "scheduledTime": { "type": "number", "minimum": 0 },
    "pubType":        { "type": "number", "enum": [0, 1], "default": 1 }
  },
  "additionalProperties": false
}
