{
  "title": "腾讯视频视频发布表单 (TengxunShipin Video)",
  "type": "object",
  "required": [
    "formType",
    "title"
  ],
  "properties": {
    "formType": {
      "type": "string",
      "const": "task"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "declaration": {
      "type": "number",
      "enum": [
        1,
        2,
        3,
        4
      ]
    },
    "video": {
      "type": "object",
      "required": [
        "key",
        "size",
        "width",
        "height"
      ],
      "properties": {
        "key": {
          "type": "string"
        },
        "size": {
          "type": "integer",
          "minimum": 1
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "duration": {
          "type": "number",
          "minimum": 1
        },
        "format": {
          "type": "string",
          "enum": [
            "mp4",
            "mov",
            "flv",
            "mkv"
          ]
        }
      }
    },
    "cover": {
      "type": "object",
      "required": [
        "key",
        "size",
        "width",
        "height"
      ],
      "properties": {
        "key": {
          "type": "string"
        },
        "size": {
          "type": "integer"
        },
        "width": {
          "type": "integer"
        },
        "height": {
          "type": "integer"
        }
      }
    },
    "coverKey": {
      "type": "string"
    },
    "scheduledTime": {
      "type": "number",
      "minimum": 0
    },
    "pubType": {
      "type": "number",
      "enum": [
        0,
        1
      ],
      "default": 1
    }
  },
  "additionalProperties": false
}
