{
  "title": "豆瓣文章发布表单 (DouBan Article)",
  "type": "object",
  "required": [
    "formType",
    "title",
    "content",
    "createType",
    "pubType"
  ],
  "properties": {
    "formType": {
      "type": "string",
      "const": "task"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "content": {
      "type": "string",
      "minLength": 1
    },
    "createType": {
      "type": "number",
      "enum": [
        0,
        1
      ],
      "default": 1
    },
    "pubType": {
      "type": "number",
      "enum": [
        0,
        1
      ],
      "default": 1
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
