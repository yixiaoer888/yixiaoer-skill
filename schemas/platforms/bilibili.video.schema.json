{
  "title": "B站视频发布表单 (Bilibili Video)",
  "type": "object",
  "required": [
    "formType",
    "title",
    "tags",
    "category",
    "createType",
    "pubType"
  ],
  "properties": {
    "formType": {
      "type": "string",
      "const": "task"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "description": {
      "type": "string",
      "minLength": 0,
      "maxLength": 2000
    },
    "video": {
      "type": "object",
      "required": [
        "key",
        "size",
        "width",
        "height"
      ],
      "properties": {
        "key": {
          "type": "string"
        },
        "size": {
          "type": "integer",
          "minimum": 1
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "duration": {
          "type": "number",
          "minimum": 1
        },
        "format": {
          "type": "string",
          "enum": [
            "mp4",
            "mov",
            "flv"
          ]
        }
      }
    },
    "cover": {
      "type": "object",
      "required": [
        "key",
        "size",
        "width",
        "height"
      ],
      "properties": {
        "key": {
          "type": "string"
        },
        "size": {
          "type": "integer"
        },
        "width": {
          "type": "integer"
        },
        "height": {
          "type": "integer"
        }
      }
    },
    "coverKey": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "type": "string",
        "maxLength": 20
      }
    },
    "category": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "yixiaoerId",
          "yixiaoerName",
          "raw"
        ],
        "properties": {
          "yixiaoerId": {
            "type": "string"
          },
          "yixiaoerName": {
            "type": "string"
          },
          "raw": {
            "type": "object"
          }
        }
      }
    },
    "declaration": {
      "type": "number",
      "enum": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ]
    },
    "createType": {
      "type": "number",
      "enum": [
        1,
        2
      ],
      "default": 1
    },
    "pubType": {
      "type": "number",
      "enum": [
        0,
        1
      ],
      "default": 1
    },
    "scheduledTime": {
      "type": "number",
      "minimum": 0
    },
    "contentSourceUrl": {
      "type": "string"
    },
    "collection": {
      "type": "object",
      "required": [
        "yixiaoerId",
        "yixiaoerName"
      ],
      "properties": {
        "yixiaoerId": {
          "type": "string"
        },
        "yixiaoerName": {
          "type": "string"
        }
      }
    }
  },
  "additionalProperties": false
}
