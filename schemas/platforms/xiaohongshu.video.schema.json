{
  "title": "小红书视频发布表单 (XiaoHongShu Video)",
  "type": "object",
  "required": [
    "formType",
    "visibleType"
  ],
  "properties": {
    "formType": {
      "type": "string",
      "const": "task"
    },
    "title": {
      "type": "string",
      "maxLength": 20
    },
    "description": {
      "type": "string",
      "maxLength": 1000
    },
    "visibleType": {
      "type": "number",
      "enum": [
        0,
        1,
        3
      ],
      "default": 0
    },
    "declaration": {
      "type": "number",
      "enum": [
        1,
        2
      ]
    },
    "createType": {
      "type": "number",
      "enum": [
        0,
        1
      ],
      "default": 0
    },
    "location": {
      "type": "object",
      "required": [
        "yixiaoerId",
        "yixiaoerName",
        "raw"
      ],
      "properties": {
        "yixiaoerId": {
          "type": "string"
        },
        "yixiaoerName": {
          "type": "string"
        },
        "raw": {
          "type": "object"
        }
      }
    },
    "collection": {
      "type": "object",
      "required": [
        "yixiaoerId",
        "yixiaoerName",
        "raw"
      ],
      "properties": {
        "yixiaoerId": {
          "type": "string"
        },
        "yixiaoerName": {
          "type": "string"
        },
        "raw": {
          "type": "object"
        }
      }
    },
    "group": {
      "type": "object",
      "required": [
        "yixiaoerId",
        "yixiaoerName",
        "raw"
      ],
      "properties": {
        "yixiaoerId": {
          "type": "string"
        },
        "yixiaoerName": {
          "type": "string"
        },
        "raw": {
          "type": "object"
        }
      }
    },
    "bind_live_info": {
      "type": "object",
      "required": [
        "yixiaoerId",
        "yixiaoerName",
        "raw"
      ],
      "properties": {
        "yixiaoerId": {
          "type": "string"
        },
        "yixiaoerName": {
          "type": "string"
        },
        "raw": {
          "type": "object"
        }
      }
    },
    "shopping_cart": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "yixiaoerId",
          "yixiaoerName",
          "raw"
        ],
        "properties": {
          "yixiaoerId": {
            "type": "string"
          },
          "yixiaoerName": {
            "type": "string"
          },
          "raw": {
            "type": "object"
          }
        }
      }
    },
    "video": {
      "type": "object",
      "required": [
        "key",
        "size",
        "width",
        "height"
      ],
      "properties": {
        "key": {
          "type": "string"
        },
        "size": {
          "type": "integer",
          "minimum": 1
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "duration": {
          "type": "number",
          "minimum": 1
        },
        "format": {
          "type": "string",
          "enum": [
            "mp4",
            "mov",
            "flv",
            "avi"
          ]
        }
      }
    },
    "cover": {
      "type": "object",
      "required": [
        "key",
        "size",
        "width",
        "height"
      ],
      "properties": {
        "key": {
          "type": "string"
        },
        "size": {
          "type": "integer"
        },
        "width": {
          "type": "integer"
        },
        "height": {
          "type": "integer"
        }
      }
    },
    "coverKey": {
      "type": "string"
    },
    "scheduledTime": {
      "type": "number",
      "minimum": 0
    },
    "pubType": {
      "type": "number",
      "enum": [
        0,
        1
      ],
      "default": 1
    }
  },
  "additionalProperties": false
}
