{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://www.yixiaoer.cn/schemas/platforms/acfun.article.schema.json",
  "title": "AcFun 文章发布表单 (AcFun Article)",
  "type": "object",
  "required": ["formType", "title", "content", "covers", "category", "type"],
  "properties": {
    "formType":        { "type": "string", "const": "task" },
    "title":           { "type": "string", "minLength": 1, "maxLength": 50 },
    "content":         { "type": "string", "minLength": 1, "maxLength": 50000 },
    "covers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["key", "size", "width", "height"],
        "properties": {
          "key":    { "type": "string" },
          "size":   { "type": "integer", "minimum": 1 },
          "width":  { "type": "integer", "minimum": 1 },
          "height": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "category": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["yixiaoerId", "yixiaoerName", "raw"],
        "properties": {
          "yixiaoerId":   { "type": "string" },
          "yixiaoerName": { "type": "string" },
          "raw":            { "type": "object" }
        }
      }
    },
    "type":            { "type": "number", "enum": [0, 1], "default": 0 },
    "desc":            { "type": "string", "maxLength": 200 },
    "tags": {
      "type": "array",
      "maxItems": 1,
      "items": { "type": "string" }
    },
    "contentSourceUrl": { "type": "string", "format": "uri" },
    "pubType":         { "type": "number", "enum": [0, 1], "default": 1 },
    "scheduledTime":   { "type": "number", "minimum": 0 }
  },
  "additionalProperties": false
}
