{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://www.yixiaoer.cn/schemas/platforms/douyin.image-text.json",
  "title": "抖音图文发布表单 (Douyin Image-Text)",
  "type": "object",
  "required": ["formType", "title", "description", "images"],
  "properties": {
    "formType":     { "type": "string", "const": "task" },
    "title":        { "type": "string", "minLength": 1, "maxLength": 50 },
    "description":  { "type": "string", "minLength": 1, "maxLength": 500 },
    "images": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "object",
        "required": ["key", "size", "width", "height"],
        "properties": {
          "key":    { "type": "string" },
          "size":   { "type": "integer", "minimum": 1 },
          "width":  { "type": "integer", "minimum": 1 },
          "height": { "type": "integer", "minimum": 1 },
          "format": { "type": "string", "enum": ["jpg", "jpeg", "png", "webp"] }
        }
      }
    },
    "cover": {
      "type": "object",
      "required": ["key", "size", "width", "height"],
      "properties": {
        "key":    { "type": "string" },
        "size":   { "type": "integer" },
        "width":  { "type": "integer" },
        "height": { "type": "integer" }
      }
    },
    "coverKey": { "type": "string" },
    "allowTake": { "type": "boolean", "default": true },
    "location": {
      "type": "object",
      "required": ["yixiaoerId", "yixiaoerName", "raw"],
      "properties": {
        "yixiaoerId":   { "type": "string" },
        "yixiaoerName": { "type": "string" },
        "raw":            { "type": "object" }
      }
    },
    "music": {
      "type": "object",
      "required": ["yixiaoerId", "yixiaoerName", "raw"],
      "properties": {
        "yixiaoerId":   { "type": "string" },
        "yixiaoerName": { "type": "string" },
        "duration":       { "type": "number" },
        "playUrl":        { "type": "string" },
        "raw":            { "type": "object" }
      }
    },
    "challenge": {
      "type": "object",
      "required": ["yixiaoerId", "yixiaoerName", "raw"],
      "properties": {
        "yixiaoerId":   { "type": "string" },
        "yixiaoerName": { "type": "string" },
        "raw":            { "type": "object" }
      }
    },
    "collection": {
      "type": "object",
      "required": ["yixiaoerId", "yixiaoerName", "raw"],
      "properties": {
        "yixiaoerId":   { "type": "string" },
        "yixiaoerName": { "type": "string" },
        "raw":            { "type": "object" }
      }
    },
    "statement": { "type": "number", "enum": [3, 4, 5, 6] }
  },
  "additionalProperties": false
}
