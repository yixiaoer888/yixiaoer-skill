{
  "title": "简书文章发布表单 (JianShu Article)",
  "type": "object",
  "required": [
    "formType",
    "title",
    "content",
    "pubType"
  ],
  "properties": {
    "formType": {
      "type": "string",
      "const": "task"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "content": {
      "type": "string",
      "minLength": 1
    },
    "pubType": {
      "type": "number",
      "enum": [
        0,
        1
      ],
      "default": 1
    }
  },
  "additionalProperties": false
}
