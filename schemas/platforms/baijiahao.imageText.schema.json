{
  "title": "百家号图文发布表单 (BaiJiaHao Image-Text)",
  "type": "object",
  "required": [
    "formType",
    "title",
    "description",
    "images",
    "pubType",
    "declaration"
  ],
  "properties": {
    "formType": {
      "type": "string",
      "const": "task"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 20
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "images": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "key",
          "size",
          "width",
          "height"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "size": {
            "type": "integer",
            "minimum": 1
          },
          "width": {
            "type": "integer",
            "minimum": 1
          },
          "height": {
            "type": "integer",
            "minimum": 1
          },
          "format": {
            "type": "string",
            "enum": [
              "jpg",
              "jpeg",
              "png",
              "webp"
            ]
          }
        }
      }
    },
    "coverKey": {
      "type": "string"
    },
    "pubType": {
      "type": "number",
      "enum": [
        0,
        1
      ],
      "default": 1
    },
    "declaration": {
      "type": "number",
      "enum": [
        0,
        1
      ],
      "default": 0
    },
    "location": {
      "type": "object",
      "required": [
        "yixiaoerId",
        "yixiaoerName",
        "raw"
      ],
      "properties": {
        "yixiaoerId": {
          "type": "string"
        },
        "yixiaoerName": {
          "type": "string"
        },
        "raw": {
          "type": "object"
        }
      }
    },
    "scheduledTime": {
      "type": "number",
      "minimum": 0
    }
  },
  "additionalProperties": false
}
