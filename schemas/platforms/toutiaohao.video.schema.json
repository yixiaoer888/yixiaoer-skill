{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://www.yixiaoer.cn/schemas/platforms/toutiaohao.video.schema.json",
  "title": "头条号视频发布表单 (Toutiaohao Video)",
  "type": "object",
  "required": ["formType", "title", "description", "tags", "visibleType", "pubType"],
  "properties": {
    "formType":       { "type": "string", "const": "task" },
    "title":          { "type": "string", "minLength": 1, "maxLength": 80 },
    "description":     { "type": "string", "minLength": 1, "maxLength": 400 },
    "tags": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": { "type": "string", "minLength": 1, "maxLength": 20 }
    },
    "visibleType":    { "type": "number", "enum": [0, 1], "default": 0 },
    "pubType":        { "type": "number", "enum": [0, 1], "default": 1 },
    "declaration":     { "type": "number", "enum": [1, 2, 3, 6, 7, 8] },
    "scheduledTime":  { "type": "number", "minimum": 0 },
    "video": {
      "type": "object",
      "required": ["key", "size", "width", "height"],
      "properties": {
        "key":      { "type": "string" },
        "size":     { "type": "integer", "minimum": 1 },
        "width":    { "type": "integer", "minimum": 1 },
        "height":   { "type": "integer", "minimum": 1 },
        "duration": { "type": "number", "minimum": 1 },
        "format":   { "type": "string", "enum": ["mp4", "mov", "flv"] }
      }
    },
    "cover": {
      "type": "object",
      "required": ["key", "size", "width", "height"],
      "properties": {
        "key":    { "type": "string" },
        "size":   { "type": "integer" },
        "width":  { "type": "integer" },
        "height": { "type": "integer" }
      }
    },
    "coverKey": { "type": "string" }
  },
  "additionalProperties": false
}
