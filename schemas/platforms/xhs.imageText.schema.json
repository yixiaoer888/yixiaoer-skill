{
  "title": "Xiaohongshu Image-Text Publish Form (Strict Standards)",
  "type": "object",
  "required": [
    "formType",
    "description",
    "images",
    "visibleType"
  ],
  "properties": {
    "formType": {
      "type": "string",
      "const": "task"
    },
    "title": {
      "type": "string",
      "maxLength": 20
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "visibleType": {
      "type": "number",
      "enum": [
        0,
        1,
        3
      ],
      "default": 0
    },
    "images": {
      "type": "array",
      "minItems": 1,
      "maxItems": 9,
      "items": {
        "type": "object",
        "required": [
          "key",
          "size",
          "width",
          "height",
          "format"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "size": {
            "type": "integer"
          },
          "width": {
            "type": "integer"
          },
          "height": {
            "type": "integer"
          },
          "format": {
            "type": "string",
            "enum": [
              "jpg",
              "jpeg",
              "png",
              "gif",
              "webp"
            ]
          }
        }
      }
    },
    "location": {
      "type": "object",
      "required": [
        "yixiaoerId",
        "yixiaoerName",
        "raw"
      ]
    },
    "music": {
      "type": "object",
      "required": [
        "yixiaoerId",
        "yixiaoerName",
        "raw"
      ],
      "properties": {
        "yixiaoerId": {
          "type": "string"
        },
        "yixiaoerName": {
          "type": "string"
        },
        "duration": {
          "type": "number"
        },
        "playUrl": {
          "type": "string"
        },
        "raw": {
          "type": "object"
        }
      }
    },
    "collection": {
      "type": "object",
      "required": [
        "yixiaoerId",
        "yixiaoerName",
        "raw"
      ]
    },
    "scheduledTime": {
      "type": "number",
      "minimum": 0
    }
  },
  "additionalProperties": false
}
