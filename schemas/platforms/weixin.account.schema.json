{
  "title": "微信公众号发布表单 (Weixin Account)",
  "type": "object",
  "required": [
    "formType",
    "title",
    "content",
    "thumbMediaId"
  ],
  "properties": {
    "formType": {
      "type": "string",
      "const": "task"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "content": {
      "type": "string",
      "minLength": 1,
      "maxLength": 20000
    },
    "author": {
      "type": "string",
      "maxLength": 20
    },
    "digest": {
      "type": "string",
      "maxLength": 120
    },
    "contentSourceUrl": {
      "type": "string",
      "format": "uri"
    },
    "thumbMediaId": {
      "type": "string"
    },
    "cover": {
      "type": "object",
      "required": [
        "key",
        "size",
        "width",
        "height"
      ],
      "properties": {
        "key": {
          "type": "string"
        },
        "size": {
          "type": "integer",
          "minimum": 1
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "coverKey": {
      "type": "string"
    },
    "needOpenComment": {
      "type": "number",
      "enum": [
        0,
        1
      ],
      "default": 1
    },
    "onlyFansCanComment": {
      "type": "number",
      "enum": [
        0,
        1
      ],
      "default": 0
    },
    "pubType": {
      "type": "number",
      "enum": [
        0,
        1
      ],
      "default": 1
    },
    "notifySubscribers": {
      "type": "number",
      "enum": [
        0,
        1
      ],
      "default": 0
    },
    "sex": {
      "type": "number",
      "enum": [
        0,
        1,
        2
      ],
      "default": 0
    },
    "country": {
      "type": "string"
    },
    "province": {
      "type": "string"
    },
    "city": {
      "type": "string"
    },
    "scheduledTime": {
      "type": "number"
    }
  },
  "additionalProperties": false
}
